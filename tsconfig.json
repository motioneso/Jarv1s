{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@jarv1s/auth": ["packages/auth/src/index.ts"],
      "@jarv1s/ai": ["packages/ai/src/index.ts"],
      "@jarv1s/briefings": ["packages/briefings/src/index.ts"],
      "@jarv1s/calendar": ["packages/calendar/src/index.ts"],
      "@jarv1s/chat": ["packages/chat/src/index.ts"],
      "@jarv1s/chat/live": ["packages/chat/src/live/public.ts"],
      "@jarv1s/chat/priority-consumer": ["packages/chat/src/priority-consumer.ts"],
      "@jarv1s/connectors": ["packages/connectors/src/index.ts"],
      "@jarv1s/connectors/presets": ["packages/connectors/src/imap-presets.ts"],
      "@jarv1s/datasets": ["packages/datasets/src/index.ts"],
      "@jarv1s/host-fetch/policy": ["packages/host-fetch/src/policy.ts"],
      "@jarv1s/db": ["packages/db/src/index.ts"],
      "@jarv1s/db/probes": ["packages/db/src/probes/index.ts"],
      "@jarv1s/db/*": ["packages/db/src/*"],
      "@jarv1s/email": ["packages/email/src/index.ts"],
      "@jarv1s/jobs": ["packages/jobs/src/index.ts"],
      "@jarv1s/jobs/*": ["packages/jobs/src/*"],
      "@jarv1s/module-registry": ["packages/module-registry/src/index.ts"],
      "@jarv1s/module-registry/node": ["packages/module-registry/src/node.ts"],
      "@jarv1s/module-sdk": ["packages/module-sdk/src/index.ts"],
      "@jarv1s/module-sdk/ai-capabilities": ["packages/module-sdk/src/ai-capabilities.ts"],
      "@jarv1s/module-web-sdk": ["packages/module-web-sdk/src/index.ts"],
      "@jarv1s/news": ["packages/news/src/index.ts"],
      "@jarv1s/news/web": ["packages/news/src/web/index.tsx"],
      "@jarv1s/notifications": ["packages/notifications/src/index.ts"],
      "@jarv1s/priority": ["packages/priority/src/index.ts"],
      "@jarv1s/settings": ["packages/settings/src/index.ts"],
      "@jarv1s/settings-ui": ["packages/settings-ui/src/index.tsx"],
      "@jarv1s/settings-ui/vite": ["packages/settings-ui/src/vite.ts"],
      "@jarv1s/shared": ["packages/shared/src/index.ts"],
      "@jarv1s/sports": ["packages/sports/src/index.ts"],
      "@jarv1s/sports/web": ["packages/sports/src/web/index.tsx"],
      "@jarv1s/source-behaviors": ["packages/source-behaviors/src/index.ts"],
      "@jarv1s/tasks": ["packages/tasks/src/index.ts"],
      "@jarv1s/memory": ["packages/memory/src/index.ts"],
      "@jarv1s/usefulness-feedback": ["packages/usefulness-feedback/src/index.ts"],
      "@jarv1s/vault": ["packages/vault/src/index.ts"],
      "@jarv1s/structured-state": ["packages/structured-state/src/index.ts"],
      "@jarv1s/web-research": ["packages/web-research/src/index.ts"],
      "@jarv1s/weather": ["packages/weather/src/index.ts"],
      "@jarv1s/wellness": ["packages/wellness/src/index.ts"],
      "@jarv1s/notes": ["packages/notes/src/index.ts"],
      "@jarv1s/proactive-monitoring": ["packages/proactive-monitoring/src/index.ts"],
      "@jarv1s/commitments": ["packages/commitments/src/index.ts"],
      "@jarv1s/commitments/extractor": ["packages/commitments/src/extractor.ts"],
      "@jarv1s/commitments/jobs": ["packages/commitments/src/jobs.ts"],
      "@jarv1s/commitments/routes": ["packages/commitments/src/routes.ts"],
      "@jarv1s/commitments/workers": ["packages/commitments/src/workers.ts"],
      "@jarv1s/commitments/prefilter": ["packages/commitments/src/prefilter.ts"],
      "@jarv1s/commitments/signature": ["packages/commitments/src/signature.ts"],
      "@jarv1s/commitments/tools": ["packages/commitments/src/tools.ts"],
      "@jarv1s/people": ["packages/people/src/index.ts"]
    }
  },
  "include": [
    "apps/api/**/*.ts",
    "apps/worker/**/*.ts",
    "apps/web/src/vite-env.d.ts",
    "packages/**/*.ts",
    "playwright.config.ts",
    "scripts/**/*.ts",
    "spikes/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
