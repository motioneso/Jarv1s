# Copy this file to an operator-managed env file outside git before production use.
# Replace every angle-bracket value. Do not use the development credentials from docker-compose.yml.

NODE_ENV=production

# Public service URL and host bindings. Production browser traffic uses
# JARVIS_WEB_PORT; JARVIS_API_PORT is kept for dev/CI tooling.
JARVIS_API_PORT=3000
JARVIS_WEB_PORT=1533
JARVIS_DOCKER_SUBNET=10.251.0.0/24
JARVIS_AUTH_BASE_URL=https://jarv1s.example.com
JARVIS_AUTH_TRUSTED_ORIGINS=https://jarv1s.example.com

# Database role URLs. Use distinct production passwords per role.
# IMPORTANT: the `postgres` superuser password embedded in JARVIS_BOOTSTRAP_DATABASE_URL
# below MUST equal POSTGRES_PASSWORD (set further down). They are two views of the SAME
# secret — POSTGRES_PASSWORD sets the superuser password when the data volume is FIRST
# initialized; JARVIS_BOOTSTRAP_DATABASE_URL authenticates migrate as that superuser. If
# they diverge (e.g. you rotate one but not the other), migrate fails fast with an auth
# error. NOTE: rotating POSTGRES_PASSWORD after first init does NOT change an existing
# volume's password (Postgres only reads it on init) — rotate inside the DB with ALTER
# ROLE, then update BOTH this URL and POSTGRES_PASSWORD to the new value.
JARVIS_BOOTSTRAP_DATABASE_URL=postgres://postgres:<bootstrap-password>@postgres:5432/jarv1s
JARVIS_MIGRATION_DATABASE_URL=postgres://jarvis_migration_owner:<migration-role-password>@postgres:5432/jarv1s
JARVIS_APP_DATABASE_URL=postgres://jarvis_app_runtime:<app-role-password>@postgres:5432/jarv1s
JARVIS_AUTH_DATABASE_URL=postgres://jarvis_auth_runtime:<auth-role-password>@postgres:5432/jarv1s
JARVIS_WORKER_DATABASE_URL=postgres://jarvis_worker_runtime:<worker-role-password>@postgres:5432/jarv1s

# Required production secrets. Generate high-entropy values and keep them stable across restarts.
BETTER_AUTH_SECRET=<generate-strong-random-secret>
JARVIS_CONNECTOR_SECRET_KEY=<generate-32-byte-base64-or-hex-secret>
JARVIS_AI_SECRET_KEY=<generate-32-byte-base64-or-hex-secret>
JARVIS_MODULE_CREDENTIAL_SECRET_KEY=<generate-32-byte-base64-or-hex-secret>

# Optional auth identity providers. Login scopes only; connector permissions stay separate.
JARVIS_AUTH_GOOGLE_CLIENT_ID=
JARVIS_AUTH_GOOGLE_CLIENT_SECRET=
JARVIS_AUTH_GITHUB_CLIENT_ID=
JARVIS_AUTH_GITHUB_CLIENT_SECRET=
JARVIS_AUTH_MICROSOFT_CLIENT_ID=
JARVIS_AUTH_MICROSOFT_CLIENT_SECRET=
JARVIS_AUTH_MICROSOFT_TENANT_ID=common
JARVIS_AUTH_MICROSOFT_AUTHORITY=
JARVIS_AUTH_OIDC_PROVIDER_ID=oidc
JARVIS_AUTH_OIDC_DISPLAY_NAME=Generic OIDC
JARVIS_AUTH_OIDC_CLIENT_ID=
JARVIS_AUTH_OIDC_CLIENT_SECRET=
JARVIS_AUTH_OIDC_DISCOVERY_URL=
JARVIS_AUTH_OIDC_ISSUER=
JARVIS_AUTH_OIDC_REQUIRE_ISSUER_VALIDATION=true

# ---------------------------------------------------------------------------
# Deployable containerized stack (docker-compose.prod.yml) — Phase 2 §5/§6/§8.
# ---------------------------------------------------------------------------

# The published GHCR image version tag the prod Compose deploys. Pin a concrete
# version (e.g. v1.2.3); NEVER :edge or :latest (a deploy must be reproducible).
JARVIS_IMAGE_TAG=v0.0.0

# Path the prod Compose's service `env_file:` uses for RUNTIME container env. NOTE:
# Compose resolves a relative `env_file` path against the COMPOSE FILE's directory
# (infra/), NOT the repo root — so this must be `./env.production.local` (which lands
# at infra/env.production.local), never `./infra/env.production.local` (that would
# resolve to infra/infra/... and fail to start). Use an absolute path if you keep the
# file elsewhere. This is SEPARATE from the `--env-file` flag below (interpolation).
JARVIS_ENV_FILE=./env.production.local

# Postgres superuser password for the prod data volume (distinct from dev). This is
# a Compose INTERPOLATION variable (it sets the postgres service's own password), so
# it is read from the SHELL env / `--env-file` at `up` time — `env_file` alone does
# NOT feed it. Deploy with `docker compose --env-file <this file> ...` (see the doc)
# so it (and JARVIS_IMAGE_TAG / JARVIS_HOST_UID etc.) actually resolve; the prod
# Compose now FAILS LOUDLY if POSTGRES_PASSWORD is unset rather than defaulting weakly.
# MUST EQUAL the `postgres:<...>` password in JARVIS_BOOTSTRAP_DATABASE_URL above — it
# is the same superuser secret, and only takes effect on FIRST volume init (see the
# note there). Keep the two in lockstep or migrate fails fast with an auth error.
POSTGRES_PASSWORD=<bootstrap-password>

# Embedding model cache (§3). The prod Compose mounts a named volume here so the
# nomic-embed-text model weights survive container restarts (no re-download).
HF_HOME=/app/.cache/huggingface

# ---------------------------------------------------------------------------
# In-container CLI chat — internal cli-runner process (#342; ADR 0010 reverses ADR 0008).
#
# The provider CLIs (claude/codex/agy) + terminal multiplexer run as an internal
# cli-runner process in the Jarv1s container. The API drives it over a private
# Unix socket; app DB/secrets stay out of the cli-runner process env.
# ---------------------------------------------------------------------------

# The container runtime user (api/worker/cli-runner) equals the host operator
# uid/gid so the init-chowned named volumes — incl. the 0700 RPC socket dir owned
# by this uid — are openable.
JARVIS_HOST_UID=1000
JARVIS_HOST_GID=1000

# Multiplexer the cli-runner forks (its OWN tmux server inside the container).
JARVIS_MULTIPLEXER=tmux

# --- cli-runner RPC (api <-> cli-runner private socket) --------------------
# Socket path inside the Jarv1s container. Setting it selects the in-container RPC
# client over the in-process engine.
JARVIS_CLI_RUNNER_SOCKET=/run/jarv1s/cli-runner.sock

# Shared secret for the socket connection auth hello (the api proves it to the
# cli-runner; the secret is NEVER sent on the wire, NEVER reaches a launched CLI).
# Known only to the API and cli-runner processes. Generate a high-entropy value (e.g.
# `openssl rand -hex 32`); setup-prod.ts generates this for you. REQUIRED — the
# prod Compose fails closed (${JARVIS_CLI_RUNNER_RPC_SECRET:?}) if unset.
JARVIS_CLI_RUNNER_RPC_SECRET=<generate-32-byte-hex-secret>

# Single-active-user gate (default 1 = ON). While ON the cli-runner holds at most
# ONE live CLI session, so no two users' 0600 token files are readable
# concurrently. Set 0 ONLY after per-UID isolation (issue #347) lands — until then
# leaving it ON is the hard runtime gate standing in for UID separation.
JARVIS_CLI_RUNNER_SINGLE_USER=1

# Loopback MCP gateway URL the launched CLIs use as the bearer target.
# The MCP bearer TOKEN is NOT set here — it arrives per-launch over the RPC.
JARVIS_MCP_SERVER_URL=http://127.0.0.1:3000/api/mcp

# --- REMOVED vars (#342) ---------------------------------------------------
# The following host-bridge vars are NO LONGER used by the prod Compose and must
# NOT be set for a containerized deploy (they referenced mounts that are gone):
#   JARVIS_TMUX_SOCKET_DIR   (host tmux socket — Jarv1s forks its own server)
#   JARVIS_HOST_CLAUDE_DIR / JARVIS_HOST_CODEX_DIR / JARVIS_HOST_GEMINI_DIR
#                            (host CLI auth dirs — Jarv1s owns provider auth)
#   JARVIS_CHAT_HOME         (host neutral-dir mount — derived inside Jarv1s)
# (These vars are still read by the code on a NATIVE host-dev install — the removal
# is compose-only. Do not set them for the containerized stack.)

# Embedding provider. "local" downloads the model on first use (cached in HF_HOME);
# set "stub" to avoid any model download (tests / explicit opt-out).
JARVIS_EMBED_PROVIDER=local

# Web search provider (optional). Brave Search API key enables the web.search tool.
# Free tier: 2000 queries/month — https://brave.com/search/api/
# Leave blank (or omit) to keep web.search in "unavailable" mode.
# JARVIS_BRAVE_SEARCH_API_KEY=
