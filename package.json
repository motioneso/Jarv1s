{
  "name": "jarv1s",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:file-size": "tsx scripts/check-file-size.ts",
    "check:design-tokens": "tsx scripts/check-design-tokens.ts",
    "check:no-ambient-dates": "tsx scripts/check-no-ambient-dates.ts",
    "check:package-deps": "tsx scripts/check-package-deps.ts",
    "check:external-modules": "tsc -p external-modules/job-search --noEmit",
    "build:external:job-search": "tsx scripts/build-external-module.ts external-modules/job-search",
    "publish:module-registry": "tsx scripts/publish-module-registry.ts --out dist/registry",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:lint": "turbo run lint",
    "typecheck": "tsc --noEmit && pnpm --filter @jarv1s/web typecheck && pnpm check:external-modules",
    "verify:foundation": "pnpm lint && pnpm format:check && pnpm check:file-size && pnpm check:design-tokens && pnpm check:no-ambient-dates && pnpm check:package-deps && pnpm typecheck && pnpm test:unit && pnpm db:migrate && pnpm test:uat-seed && pnpm test:integration",
    "db:up": "docker compose -f infra/docker-compose.yml up -d postgres greenmail --wait",
    "db:down": "docker compose -f infra/docker-compose.yml down -v",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reconcile": "tsx scripts/module-reconcile.ts",
    "backup:db": "tsx scripts/backup-database.ts",
    "restore:db": "tsx scripts/restore-database.ts",
    "export:user": "tsx scripts/export-user-data.ts",
    "delete:user": "tsx scripts/delete-user-data-cli.ts",
    "audit:preflight": "bash scripts/check-tree-fresh.sh",
    "audit:release-hardening": "tsx scripts/audit-release-hardening.ts",
    "evidence:job-search": "tsx scripts/job-search-acceptance-evidence.ts",
    "smoke:compose": "tsx scripts/smoke-compose.ts",
    "dev:api": "pnpm --filter @jarv1s/api dev",
    "dev:web": "pnpm --filter @jarv1s/web dev",
    "dev:worker": "pnpm --filter @jarv1s/worker dev",
    "start:api": "pnpm --filter @jarv1s/api start",
    "build:web": "pnpm --filter @jarv1s/web build",
    "build:api": "tsx scripts/build-app.ts api",
    "build:worker": "tsx scripts/build-app.ts worker",
    "smoke:compose:prod": "tsx scripts/smoke-compose.ts --compose-file infra/docker-compose.prod.yml --build",
    "uat:provision:smoke": "tsx tests/uat/provisioner.ts",
    "test:uat": "tsx tests/uat/run-uat.ts",
    "test:e2e": "playwright test",
    "capture:screens": "CAPTURE=1 playwright test capture-screens --workers=1",
    "start:worker": "pnpm --filter @jarv1s/worker start",
    "test:unit": "vitest run tests/unit",
    "test:uat-seed": "vitest run tests/uat/seed",
    "test:integration": "tsx scripts/test-integration.ts tests/integration",
    "test:ai": "tsx scripts/test-integration.ts tests/integration/ai.test.ts tests/integration/ai-capability-routes.test.ts tests/integration/ai-structured.test.ts",
    "test:ai-tools": "tsx scripts/test-integration.ts tests/integration/ai-tools.test.ts",
    "test:briefings": "tsx scripts/test-integration.ts tests/integration/briefings.test.ts tests/integration/briefings-synthesis.test.ts",
    "test:chat": "tsx scripts/test-integration.ts tests/integration/chat-live.test.ts",
    "test:connectors": "tsx scripts/test-integration.ts tests/integration/connectors.test.ts",
    "test:notes": "tsx scripts/test-integration.ts tests/integration/notes.test.ts",
    "test:calendar-email": "tsx scripts/test-integration.ts tests/integration/calendar-email.test.ts",
    "test:focus-time": "tsx scripts/test-integration.ts tests/integration/focus-time.test.ts tests/integration/focus-time-seam.test.ts",
    "test:calendar-delete": "tsx scripts/test-integration.ts tests/integration/calendar-delete.test.ts",
    "test:release-hardening": "tsx scripts/test-integration.ts tests/integration/release-hardening.test.ts",
    "test:shares": "tsx scripts/test-integration.ts tests/integration/shares.test.ts",
    "test:notifications": "tsx scripts/test-integration.ts tests/integration/notifications.test.ts",
    "test:tasks": "tsx scripts/test-integration.ts tests/integration/tasks.test.ts",
    "test:tasks-tools": "tsx scripts/test-integration.ts tests/integration/tasks-tools.test.ts",
    "test:commitments": "JARVIS_PGDATABASE=jarvis_build_537 vitest run tests/integration/commitments.test.ts",
    "test:wellness": "tsx scripts/test-integration.ts tests/integration/wellness.test.ts tests/integration/wellness-phase2.test.ts tests/integration/wellness-medications.test.ts",
    "test:memory": "tsx scripts/test-integration.ts tests/integration/memory.test.ts tests/integration/memory-facts-rls.test.ts tests/integration/memory-graph.test.ts",
    "test:memory:local": "tsx scripts/test-integration.ts tests/slow/memory-local-embed.test.ts",
    "ingest:vault": "tsx scripts/ingest-vault.ts",
    "test:vault": "tsx scripts/test-integration.ts tests/integration/vault.test.ts",
    "test:structured-state": "tsx scripts/test-integration.ts tests/integration/structured-state.test.ts",
    "spike:db:up": "docker compose -f spikes/auth-rls-safety/docker-compose.yml up -d --wait",
    "spike:db:down": "docker compose -f spikes/auth-rls-safety/docker-compose.yml down -v",
    "test:spike": "vitest run spikes",
    "test:spike:auth": "vitest run spikes/auth-rls-safety/test/auth-rls-safety.test.ts",
    "test:spike:pgboss": "vitest run spikes/pg-boss-rls/test/pg-boss-rls.test.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13",
    "@fastify/rate-limit": "^10",
    "fastify": "^5.6.2",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/tar": "^6.1.13",
    "@types/tar-stream": "^3.1.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "imapflow": "^1.4.3",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.7",
    "tar": "^7.5.16",
    "tar-stream": "^3.1.7",
    "tsx": "^4.21.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "ws": "^8.21.1"
  }
}
