{
  "name": "jarv1s",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:file-size": "tsx scripts/check-file-size.ts",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:lint": "turbo run lint",
    "typecheck": "tsc --noEmit && pnpm --filter @jarv1s/web typecheck",
    "verify:foundation": "pnpm lint && pnpm format:check && pnpm check:file-size && pnpm typecheck && pnpm test:unit && pnpm db:migrate && pnpm test:integration",
    "db:up": "docker compose -f infra/docker-compose.yml up -d postgres --wait",
    "db:down": "docker compose -f infra/docker-compose.yml down -v",
    "db:migrate": "tsx scripts/migrate.ts",
    "backup:db": "tsx scripts/backup-database.ts",
    "restore:db": "tsx scripts/restore-database.ts",
    "export:user": "tsx scripts/export-user-data.ts",
    "delete:user": "tsx scripts/delete-user-data.ts",
    "audit:preflight": "bash scripts/check-tree-fresh.sh",
    "audit:release-hardening": "tsx scripts/audit-release-hardening.ts",
    "smoke:compose": "tsx scripts/smoke-compose.ts",
    "dev:api": "pnpm --filter @jarv1s/api dev",
    "dev:web": "pnpm --filter @jarv1s/web dev",
    "dev:worker": "pnpm --filter @jarv1s/worker dev",
    "start:api": "pnpm --filter @jarv1s/api start",
    "build:web": "pnpm --filter @jarv1s/web build",
    "test:e2e": "playwright test",
    "start:worker": "pnpm --filter @jarv1s/worker start",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ai": "vitest run tests/integration/ai.test.ts",
    "test:ai-tools": "vitest run tests/integration/ai-tools.test.ts",
    "test:briefings": "vitest run tests/integration/briefings.test.ts",
    "test:chat": "vitest run tests/integration/chat-live.test.ts",
    "test:connectors": "vitest run tests/integration/connectors.test.ts",
    "test:calendar-email": "vitest run tests/integration/calendar-email.test.ts",
    "test:release-hardening": "vitest run tests/integration/release-hardening.test.ts",
    "test:shares": "vitest run tests/integration/shares.test.ts",
    "test:notes": "vitest run tests/integration/notes.test.ts",
    "test:notifications": "vitest run tests/integration/notifications.test.ts",
    "test:tasks": "vitest run tests/integration/tasks.test.ts",
    "test:tasks-tools": "vitest run tests/integration/tasks-tools.test.ts",
    "test:memory": "vitest run tests/integration/memory.test.ts",
    "test:memory:local": "vitest run tests/slow/memory-local-embed.test.ts",
    "ingest:vault": "tsx scripts/ingest-vault.ts",
    "test:vault": "vitest run tests/integration/vault.test.ts",
    "test:structured-state": "vitest run tests/integration/structured-state.test.ts",
    "spike:db:up": "docker compose -f spikes/auth-rls-safety/docker-compose.yml up -d --wait",
    "spike:db:down": "docker compose -f spikes/auth-rls-safety/docker-compose.yml down -v",
    "test:spike": "vitest run spikes",
    "test:spike:auth": "vitest run spikes/auth-rls-safety/test/auth-rls-safety.test.ts",
    "test:spike:pgboss": "vitest run spikes/pg-boss-rls/test/pg-boss-rls.test.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13",
    "@fastify/rate-limit": "^10",
    "fastify": "^5.6.2",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
