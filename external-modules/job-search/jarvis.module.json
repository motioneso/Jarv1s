{
  "schemaVersion": 1,
  "id": "job-search",
  "name": "Job Search",
  "version": "0.2.0",
  "publisher": "Jarvis Project",
  "lifecycle": "optional",
  "compatibility": { "jarv1s": ">=0.1.0" },
  "description": "A private, guided workspace for finding the right next role.",
  "storage": [
    { "namespace": "job-search.profiles", "scopes": ["user"] },
    { "namespace": "job-search.resume", "scopes": ["user"] },
    { "namespace": "job-search.sources", "scopes": ["user"] },
    { "namespace": "job-search.candidates", "scopes": ["user"] },
    { "namespace": "job-search.matches", "scopes": ["user"] },
    { "namespace": "job-search.feedback", "scopes": ["user"] },
    { "namespace": "job-search.settings", "scopes": ["user"] },
    { "namespace": "job-search.meta", "scopes": ["user"] }
  ],
  "runtime": { "workerEntrypoint": "dist/worker.js", "workerContractVersion": 1 },
  "assistantTools": [
    {
      "name": "job-search.profiles.list",
      "permissionId": "job-search.profiles.list",
      "description": "List your saved job-search profiles.",
      "risk": "read",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "handler": "profiles.list"
    },
    {
      "name": "job-search.resume.intake",
      "permissionId": "job-search.resume.intake",
      "description": "Save resume text from an upload, paste, or interview.",
      "risk": "write",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source"],
        "properties": {
          "source": { "type": "string", "enum": ["upload", "paste", "interview"] },
          "attachmentId": { "type": "string", "format": "uuid" },
          "text": { "type": "string", "maxLength": 120000 }
        }
      },
      "handler": "resume.intake"
    },
    {
      "name": "job-search.resume.critique",
      "permissionId": "job-search.resume.critique",
      "description": "Review the saved resume with evidence-grounded critique and revisions.",
      "risk": "write",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "handler": "resume.critique"
    }
  ],
  "assistantOnboarding": {
    "guidance": "Start every Job Search conversation with: Let's get your resume solid first. Guide the user through resume intake before profile details. Keep claims grounded in what the user provides."
  },
  "worker": {
    "queues": [
      {
        "name": "job-search.reset",
        "handler": "reset",
        "retryLimit": 1,
        "allowManualRun": false
      },
      {
        "name": "job-search.resume-revise",
        "handler": "resume-revise",
        "retryLimit": 1,
        "allowManualRun": true,
        "paramsSchema": { "type": "object", "fields": { "revisionId": { "type": "identifier" } } }
      }
    ],
    "reconcileJobs": [
      {
        "id": "reset",
        "queue": "job-search.reset",
        "jobKind": "job-search.reset"
      }
    ]
  },
  "web": { "entrypoint": "dist/web/index.js", "contractVersion": 1 },
  "navigation": [{ "id": "job-search", "label": "Job Search", "path": "/", "icon": "briefcase" }]
}
