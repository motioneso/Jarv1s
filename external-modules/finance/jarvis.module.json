{
  "schemaVersion": 1,
  "id": "finance",
  "name": "Finance",
  "version": "0.4.0",
  "publisher": "Jarvis Project",
  "lifecycle": "optional",
  "compatibility": { "jarv1s": ">=0.1.0" },
  "description": "Bank accounts, transactions, and budgets via Plaid.",
  "auth": [
    {
      "id": "finance.plaid-client-id",
      "displayName": "Plaid client id",
      "kind": "api-key",
      "scope": "instance"
    },
    {
      "id": "finance.plaid-secret",
      "displayName": "Plaid secret",
      "kind": "api-key",
      "scope": "instance"
    },
    {
      "id": "finance.plaid-tokens",
      "displayName": "Plaid access tokens",
      "kind": "api-key",
      "scope": "user"
    }
  ],
  "storage": [
    { "namespace": "finance.connections", "scopes": ["user"] },
    { "namespace": "finance.accounts", "scopes": ["user"] },
    { "namespace": "finance.transactions", "scopes": ["user"] },
    { "namespace": "finance.categories", "scopes": ["user"] },
    { "namespace": "finance.rules", "scopes": ["user"] },
    { "namespace": "finance.snapshots", "scopes": ["user"] },
    { "namespace": "finance.budgets", "scopes": ["user"] },
    { "namespace": "finance.shared", "scopes": ["instance"], "instanceWritePolicy": "module" },
    { "namespace": "finance.settings", "scopes": ["user", "instance"] }
  ],
  "runtime": { "workerEntrypoint": "dist/worker.js", "workerContractVersion": 1 },
  "assistantTools": [
    {
      "name": "finance.accounts.list",
      "permissionId": "finance.accounts.list",
      "description": "List connected bank accounts with live balances.",
      "risk": "read",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "handler": "accounts.list"
    },
    {
      "name": "finance.connect.start",
      "permissionId": "finance.connect.start",
      "description": "Start connecting a bank via Plaid Hosted Link; returns a link URL to open.",
      "risk": "write",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "environment": { "type": "string", "enum": ["production", "sandbox"] } }
      },
      "handler": "connect.start"
    },
    {
      "name": "finance.connect.poll",
      "permissionId": "finance.connect.poll",
      "description": "Check pending bank connections and finish token exchange.",
      "risk": "write",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "handler": "connect.poll"
    },
    {
      "name": "finance.sync.run-now",
      "permissionId": "finance.sync.run-now",
      "description": "Sync accounts and transactions from Plaid now.",
      "risk": "write",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "handler": "sync.run"
    },
    {
      "name": "finance.transactions.query",
      "permissionId": "finance.transactions.query",
      "description": "Query synced transactions by month, account, category, or text.",
      "risk": "read",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "accountId": { "type": "string" },
          "categoryId": { "type": "string" },
          "search": { "type": "string" },
          "pendingOnly": { "type": "boolean" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 200 }
        }
      },
      "handler": "transactions.query"
    },
    {
      "name": "finance.transaction.categorize",
      "permissionId": "finance.transaction.categorize",
      "description": "Set a transaction's category, optionally creating a payee rule.",
      "risk": "write",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "transactionId": { "type": "string" },
          "accountId": { "type": "string" },
          "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "categoryId": { "type": "string" },
          "createRule": { "type": "boolean" },
          "notes": { "type": "string", "maxLength": 500 }
        },
        "required": ["transactionId", "accountId", "month", "categoryId"]
      },
      "handler": "transaction.categorize"
    },
    {
      "name": "finance.budget.status",
      "permissionId": "finance.budget.status",
      "description": "Show the envelope budget for a month: to-be-budgeted, assigned, activity, and available per category.",
      "risk": "read",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" } },
        "required": ["month"]
      },
      "handler": "budget.status"
    },
    {
      "name": "finance.budget.assign",
      "permissionId": "finance.budget.assign",
      "description": "Set a category's assigned amount for a month (envelope budgeting).",
      "risk": "write",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "categoryId": { "type": "string" },
          "amountCents": { "type": "integer", "minimum": -100000000, "maximum": 100000000 }
        },
        "required": ["month", "categoryId", "amountCents"]
      },
      "handler": "budget.assign"
    },
    {
      "name": "finance.account.set-shared",
      "permissionId": "finance.account.set-shared",
      "description": "Share or unshare one of your bank accounts with the household.",
      "risk": "write",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "accountId": { "type": "string" },
          "shared": { "type": "boolean" }
        },
        "required": ["accountId", "shared"]
      },
      "handler": "account.set-shared"
    },
    {
      "name": "finance.reports.spending",
      "permissionId": "finance.reports.spending",
      "description": "Monthly spending by category and payee plus cash flow (income, outflow, net) over a window of recent months, including household-shared accounts.",
      "risk": "read",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "months": { "type": "integer", "minimum": 1, "maximum": 24 }
        }
      },
      "handler": "reports.spending"
    },
    {
      "name": "finance.reports.net-worth",
      "permissionId": "finance.reports.net-worth",
      "description": "Daily net-worth series and current headline from your own account balance snapshots (liabilities negated).",
      "risk": "read",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "months": { "type": "integer", "minimum": 1, "maximum": 24 }
        }
      },
      "handler": "reports.net-worth"
    }
  ],
  "worker": {
    "queues": [
      {
        "name": "finance.sync-run",
        "handler": "sync.run",
        "retryLimit": 3,
        "allowManualRun": true
      },
      {
        "name": "finance.connect-poll",
        "handler": "connect.poll",
        "retryLimit": 5,
        "allowManualRun": true
      },
      {
        "name": "finance.categorize-apply",
        "handler": "categorize.apply",
        "retryLimit": 1,
        "allowManualRun": true,
        "paramsSchema": {
          "type": "object",
          "fields": {
            "accountId": { "type": "identifier" },
            "month": { "type": "identifier" },
            "transactionId": { "type": "identifier" },
            "categoryId": { "type": "identifier" }
          }
        }
      },
      {
        "name": "finance.budget-apply",
        "handler": "budget.apply",
        "retryLimit": 1,
        "allowManualRun": true,
        "paramsSchema": {
          "type": "object",
          "fields": {
            "month": { "type": "identifier" },
            "categoryId": { "type": "identifier" },
            "amountCents": { "type": "integer", "min": -100000000, "max": 100000000 }
          }
        }
      },
      {
        "name": "finance.share-apply",
        "handler": "share.apply",
        "retryLimit": 1,
        "allowManualRun": true,
        "paramsSchema": {
          "type": "object",
          "fields": {
            "accountId": { "type": "identifier" },
            "shared": { "type": "boolean" }
          }
        }
      }
    ],
    "schedules": [
      {
        "id": "finance.sync-sweep",
        "cron": "41 */6 * * *",
        "scope": "user",
        "jobKind": "finance.sync-sweep",
        "queue": "finance.sync-run"
      }
    ]
  },
  "fetchHosts": ["production.plaid.com", "sandbox.plaid.com"],
  "web": { "entrypoint": "dist/web/index.js", "contractVersion": 1 },
  "navigation": [{ "id": "finance", "label": "Finance", "path": "/", "icon": "landmark" }]
}
