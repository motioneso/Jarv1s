# Keep the Docker build context small and never leak host artifacts/secrets.
node_modules
**/node_modules
.git
.gitignore
.github
# #1026: tests/uat/seed/** is deliberately NOT excluded below — the `seed` compose
# service (infra/docker-compose.prod.yml, #1032) runs tests/uat/seed/cli.ts *inside*
# this image, and its imports are self-contained under tests/uat/seed/ (verified: no
# reach into tests/e2e, tests/unit, etc). Everything else under tests/ stays excluded.
tests/*.test.ts
tests/e2e
tests/fixtures
tests/integration
tests/scripts
tests/setup-env.ts
tests/slow
tests/unit
tests/uat/*.ts
tests/uat/specs
spikes
external-modules
# #1110: build-app-map.ts reads docs/WHATS_NEW.md at image-build time as the app-map
# narrative field, so it can't be blanket-excluded like the rest of docs/.
docs/*
!docs/WHATS_NEW.md
backups
exports
**/dist
.codegraph
.turbo
playwright-report
test-results
# Secrets: the *.env globs do NOT match a `foo.production.local` suffix, so list
# the operator env file EXPLICITLY (Task 11 creates it in the build context).
*.env
*.env.*
infra/env.production.local
**/env.production.local
**/*.local.env
.env*
!infra/env.production.example
.DS_Store
*.log
